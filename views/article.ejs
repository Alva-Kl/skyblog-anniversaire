<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="flash <%= flash.type %>"><%= flash.msg %></div>
<% } %>

<div class="article-full">
  <div class="article-title-bar">
    <h2><%= article.title %></h2>
  </div>
  <div class="article-body">
    <%- article.content %>
  </div>
  <% if (article.photos && article.photos.length > 0) { %>
    <div class="article-photos">
      <% article.photos.forEach(function(photo) { %>
        <div class="article-photo-item">
          <img src="/uploads/<%= photo.filename %>"
               alt=""
               onclick="openLightbox('/uploads/<%= photo.filename %>', '')"
               loading="lazy">
        </div>
      <% }); %>
    </div>
  <% } %>
  <div class="article-footer">
    <div class="article-meta">
      <span>Posté le <span class="js-local-datetime" data-utc="<%= article.created_at %>"><%= article.created_at %></span></span>
      <% if (article.updated_at && article.updated_at !== article.created_at) { %>
        &nbsp;· Modifié le <span class="js-local-datetime" data-utc="<%= article.updated_at %>"><%= article.updated_at %></span>
      <% } %>
      <span>par <span class="author"><%= article.author_name %></span></span>
    </div>
    <div class="article-votes vote-bar">
      <%- voteButtons(article, user) %>
    </div>
    <div class="article-actions">
      <% if (user && (user.id === article.author_id || user.is_admin)) { %>
        <a href="/article/<%= article.id %>/edit" class="edit">✏️ Modifier</a>
        <form method="POST" action="/article/<%= article.id %>/delete" style="display:inline;" data-confirm="Supprimer cet article ?">
          <button type="submit" class="delete">🗑 Supprimer</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<div style="margin-top:8px;">
  <a href="/" class="btn btn-secondary">← Retour au blog</a>
</div>

<!-- COMMENTS SECTION -->
<div id="comments" class="comments-section">
  <div class="comments-header">
    💬 Commentaires (<%= article.comments ? article.comments.length : 0 %>)
  </div>

  <% if (article.comments && article.comments.length > 0) { %>
    <% article.comments.forEach(function(comment) { %>
      <div class="comment-item">
        <div class="comment-meta">
          <span class="comment-author"><%= comment.author_name %></span>
          <span class="comment-date js-local-datetime" data-utc="<%= comment.created_at %>"><%= comment.created_at %></span>
          <% if (user && (user.id === comment.author_id || user.is_admin)) { %>
            <form method="POST" action="/comment/<%= comment.id %>/delete" style="display:inline;" data-confirm="Supprimer ce commentaire ?">
              <button type="submit" class="comment-delete">✕ Supprimer</button>
            </form>
          <% } %>
        </div>
        <div class="comment-content"><%= comment.content %></div>
      </div>
    <% }); %>
  <% } else { %>
    <div class="comment-empty">Soyez le premier à commenter ! 💕</div>
  <% } %>

  <% if (user) { %>
    <div class="comment-form-wrap">
      <div class="comments-header" style="font-size:11px;">Laisser un commentaire</div>
      <form method="POST" action="/article/<%= article.id %>/comment" class="comment-form">
        <textarea name="content" rows="3" placeholder="Écris ton commentaire..." required maxlength="1000"></textarea>
        <button type="submit" class="btn" style="margin-top:6px;">💬 Commenter</button>
      </form>
    </div>
  <% } else { %>
    <div class="comment-login-prompt">
      <a href="/login">Connecte-toi</a> pour laisser un commentaire.
    </div>
  <% } %>
</div>
