  </div>

  <script src="/js/main.js"></script>
  <script src="https://open.spotify.com/embed/iframe-api/v1" async></script>
  <script>
    // Spotify IFrame API — runs once, player persists across PJAX navigation
    var _pageBaseTitle = document.title;

    window.onSpotifyIframeApiReady = function(IFrameAPI) {
      // Guard: prevent reinitializing player (only create once, persists across page navigation)
      if (window._spotifyController) return;
      
      var el = document.getElementById('spotify-player');
      if (!el) return;
      var options = {
        uri: 'spotify:playlist:1JEny7rbDkbd2mSVaRdDrr',
        height: '400',
        width: '100%'
      };
      IFrameAPI.createController(el, options, function(EmbedController) {
        window._spotifyController = EmbedController;

        // Guard: only call play() once — 'ready' can fire multiple times
        // (once when the controller loads, again when the playlist resolves).
        // A second play() call toggles the embed to paused.
        var _played = false;
        EmbedController.addListener('ready', function() {
          if (!_played) { _played = true; EmbedController.play(); }
        });

        function updateNowPlaying(name) {
          if (!name) return;
          var npEl = document.getElementById('np-title');
          if (npEl) npEl.textContent = name;
          document.title = '♪ ' + name + ' — ' + _pageBaseTitle;
        }

        // The IFrame API passes the payload DIRECTLY to the callback (no .data wrapper).
        // Track name lives at e.track_window.current_track.name
        EmbedController.addListener('playback_update', function(e) {
          var name =
            (e && e.track_window && e.track_window.current_track && e.track_window.current_track.name) ||
            (e && e.data && e.data.track_window && e.data.track_window.current_track && e.data.track_window.current_track.name) ||
            (e && e.data && e.data.track && e.data.track.name) ||
            (e && e.track && e.track.name) ||
            null;
          if (name) updateNowPlaying(name);
        });

        // Poll for current track every 2 seconds as a fallback
        window._spotifyNowPlayingInterval = setInterval(function() {
          EmbedController.getStatus(function(status) {
            if (status && status.playerState && status.playerState.track && status.playerState.track.name) {
              updateNowPlaying(status.playerState.track.name);
            }
          });
        }, 2000);
      });
    };

    // Raw postMessage fallback — intercept Spotify iframe messages directly
    // in case the IFrame API abstraction loses the track data
    window.addEventListener('message', function(evt) {
      if (!String(evt.origin).includes('spotify')) return;
      var d = evt.data;
      if (typeof d === 'string') { try { d = JSON.parse(d); } catch(_) { return; } }
      var payload = (d && d.payload) || d;
      var tw = payload && payload.track_window;
      if (tw && tw.current_track && tw.current_track.name) {
        var name = tw.current_track.name;
        var npEl = document.getElementById('np-title');
        if (npEl) npEl.textContent = name;
        document.title = '♪ ' + name + ' — ' + _pageBaseTitle;
      }
    });
  </script>
</body>
</html>
