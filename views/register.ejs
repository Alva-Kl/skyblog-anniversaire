<div class="form-page">
  <h1>⭐ allé vi1 ⭐</h1>
  <% if (error) { %>
    <div class="form-error"><%= error %></div>
  <% } %>
  <form method="POST" action="/register">
    <div class="form-group">
      <label>Pseudo <small style="color:#666;">(min. 3 caractères)</small></label>
      <input type="text" name="username" autocomplete="username" required autofocus minlength="3">
    </div>
    <div class="form-group">
      <label>Mot de passe <small style="color:#666;">(min. 6 caractères)</small></label>
      <input type="password" name="password" autocomplete="new-password" required minlength="6">
    </div>
    <div class="form-group">
      <label>Confirmer le mot de passe</label>
      <input type="password" name="confirm" autocomplete="new-password" required minlength="6">
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;">
      <button type="submit" class="btn">S'inscrire</button>
      <a href="/login" style="font-size:11px;color:#888;">Déjà inscrit(e) ?</a>
    </div>
  </form>
</div>
